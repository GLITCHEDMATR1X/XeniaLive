+XSessionDetails XLiveAPI::EnsureSinglePlayerHostSession(
+    uint32_t title_id, uint64_t host_xuid, uint32_t host_address) {
+  if (!IsSinglePlayerHostEnabled()) {
+    return {};
+  }
+  const auto existing =
+      sessions_.GetSession(kCodeRedSinglePlayerHostSessionPtr);
+  if (existing.has_value()) {
+    return *existing;
+  }
+  if (!host_address) {
+    host_address = util::GetConfiguredIPv4NetworkOrder();
+  }
+
+  XSessionCreateParams params;
+  params.title_id = title_id;
+  params.session_ptr = kCodeRedSinglePlayerHostSessionPtr;
+  params.flags = SessionFlags::SYSTEMLINK_FEATURES;
+  params.public_slots = 4;
+  params.private_slots = 0;
+  params.host_xuid = host_xuid;
+  params.host_address = host_address;
+  params.port = player_port_;
+  params.mac = util::MakeStableMac(host_address);
+
+  auto session = sessions_.CreateHostSession(params);
+  sessions_.StartSession(kCodeRedSinglePlayerHostSessionPtr);
+  session =
+      sessions_.GetSession(kCodeRedSinglePlayerHostSessionPtr).value_or(session);
+  XELOGI(
+      "CodeRED Netplay: SinglePlayerHost advertise title={} session={} "
+      "host={} port={} public={} saves_disabled={} route={}",
+      FormatTitleId(title_id), FormatCodeRedSessionId(session.id),
+      util::IPv4ToString(host_address), player_port_, session.public_slots,
+      cvars::netplay_disable_saves, BuildSessionPostPath(title_id));
+
+  if (ShouldUsePrivateHost()) {
+    if (host_xuid) {
+      RegisterPlayer(host_xuid, title_id, host_address);
+    }
+    PublishSession(session, "singleplayer-host");
+  }
+  return session;
+}
